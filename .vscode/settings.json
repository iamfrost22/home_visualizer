{
  // Project-specific search exclusions. Universal junk (.venv, __pycache__,
  // node_modules, etc.) is handled in user settings; here we only add the
  // things specific to this repo.
  "search.exclude": {
    "**/data": true
  },
  // Use the project venv for Python tooling.
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python.terminal.activateEnvironment": true
}
