<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_gallery.xml -->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Scans"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your previously scanned floor plans appear here."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:fontFamily="sans-serif"
            android:layout_marginBottom="32dp"/>

        <!-- Shown when no scans exist -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No scans yet.\nHead to Home and tap Scan Floor Plan!"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:gravity="center"
            android:fontFamily="sans-serif"
            android:visibility="gone"
            android:layout_marginTop="80dp"/>

        <!-- Future: RecyclerView with scan cards -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvScans"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
