<?xml version="1.0" encoding="utf-8"?>
<!-- Hero background: a subtle grid pattern suggesting a floor plan blueprint -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="400dp"
    android:height="200dp"
    android:viewportWidth="400"
    android:viewportHeight="200">
    <!-- Grid lines horizontal -->
    <path android:strokeColor="#2200D4B4" android:strokeWidth="1"
        android:pathData="M0,40 H400 M0,80 H400 M0,120 H400 M0,160 H400"/>
    <!-- Grid lines vertical -->
    <path android:strokeColor="#2200D4B4" android:strokeWidth="1"
        android:pathData="M50,0 V200 M100,0 V200 M150,0 V200 M200,0 V200 M250,0 V200 M300,0 V200 M350,0 V200"/>
    <!-- Room outline suggestion -->
    <path android:strokeColor="#4400D4B4" android:strokeWidth="2" android:fillColor="#00000000"
        android:pathData="M80,40 H320 V160 H80 Z"/>
    <path android:strokeColor="#4400D4B4" android:strokeWidth="2" android:fillColor="#00000000"
        android:pathData="M80,100 H200 M200,40 V160"/>
</vector>
