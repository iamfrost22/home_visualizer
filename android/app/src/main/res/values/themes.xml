<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme -->
    <style name="Theme.FloorPlan3D" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_teal</item>
        <item name="colorPrimaryVariant">@color/accent_blue</item>
        <item name="colorOnPrimary">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <!-- Splash: full-screen, no system UI chrome during animation -->
    <style name="Theme.FloorPlan3D.Splash" parent="Theme.FloorPlan3D">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Scanner: keep full screen for Unity surface -->
    <style name="Theme.FloorPlan3D.Scanner" parent="Theme.FloorPlan3D">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
